{
  "name": "weekly_watchlist_refresh",
  "nodes": [
    {
      "name": "Weekly Watchlist Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "value": 1
            }
          ]
        }
      }
    },
    {
      "name": "Build Watchlist Enqueue Payload",
      "type": "n8n-nodes-base.set",
      "parameters": {
        "mode": "raw",
        "jsonOutput": "{\n  \"requested_by\": \"n8n:weekly_watchlist_refresh\"\n}"
      }
    },
    {
      "name": "Enqueue Watchlist Refresh",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/queue/enqueue-watchlist",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}"
      }
    },
    {
      "name": "Fetch Queue Summary",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "http://api:8000/queue"
      }
    }
  ],
  "connections": {
    "Weekly Watchlist Trigger": {
      "main": [
        [
          {
            "node": "Build Watchlist Enqueue Payload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Build Watchlist Enqueue Payload": {
      "main": [
        [
          {
            "node": "Enqueue Watchlist Refresh",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Enqueue Watchlist Refresh": {
      "main": [
        [
          {
            "node": "Fetch Queue Summary",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
