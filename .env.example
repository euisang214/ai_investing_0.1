AI_INVESTING_DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/ai_investing
AI_INVESTING_CONFIG_DIR=/app/config
AI_INVESTING_PROMPTS_DIR=/app/prompts
AI_INVESTING_PROVIDER=fake
AI_INVESTING_ALLOW_FAKE_FALLBACK=true
AI_INVESTING_LOG_LEVEL=INFO

# Provider API keys — set the keys for providers you want to use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# OpenAI-compatible endpoint (for Together, Fireworks, Ollama, vLLM, etc.)
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
