{
  "name": "weekly_watchlist_refresh",
  "nodes": [
    {
      "name": "Weekly Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "weeks",
              "value": 1
            }
          ]
        }
      }
    },
    {
      "name": "Run Due Coverage",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "http://api:8000/coverage/run-due"
      }
    }
  ],
  "connections": {
    "Weekly Trigger": {
      "main": [
        [
          {
            "node": "Run Due Coverage",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}

